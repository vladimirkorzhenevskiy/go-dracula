{
  "name": "go-dracula",
  "displayName": "Go Dracula",
  "description": "Semantic highlighting for Go like JetBrains Dracula",
  "version": "1.0.0",
  "publisher": "vladimirkorzhenevskiy",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladimirkorzhenevskiy/go-dracula.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "categories": [
    "Themes",
    "Programming Languages"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Go Dracula",
        "uiTheme": "vs-dark",
        "path": "./themes/go-dracula-color-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.6"
  }
}
