		// Настройка окна предварительного просмотра
		// 1. Общая рамка и заголовок
		"peekView.border": "#595959", // Серая рамка как в IDE
		"peekViewTitle.background": "#3b3e40", // Темный заголовок
		"peekViewTitleLabel.foreground": "#bbbbbb", // Текст заголовка
		"peekViewTitleDescription.foreground": "#999999", // Описание (путь к файлу)
		// 2. Левая часть (Редактор кода в окне)
